<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>

<FlowPane prefHeight="50" prefWidth="200" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="wk2.BlurController">
    <children>
        <Label fx:id="displayText" text="This is a label that contains text" />
        <Button fx:id="toggleButton" onAction="#toggleBlur" text="Blur" textFill="#d70f0f" />
    </children>
</FlowPane>
